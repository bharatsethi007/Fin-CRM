# App
NODE_ENV=development
PORT=3000

# Database (Supabase = PostgreSQL)
# Option A: Use connection string from Supabase Dashboard → Project Settings → Database
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
#
# Option B: Use individual variables (from same Supabase Database settings)
DATABASE_HOST=db.xxxxxxxxxxxx.supabase.co
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_supabase_db_password
DATABASE_NAME=postgres

# JWT
JWT_SECRET=generate-a-random-32-character-string
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=generate-another-random-32-character-string
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3
AWS_REGION=us-west-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=your-bucket-name

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
